# Environment configuration for API Gateway
NODE_ENV=development

# Connection
TRANSPORT_URL=
HTTP_PORT=
FRONTEND_URL=https://yourapp.com

# Token TTLs
EMAIL_TOKEN_TTL=3600 # 1 hour in seconds
PASSWORD_RESET_TOKEN_TTL=3600 # 1 hour in seconds

# Database
DATABASE_URL=

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_ACCESS_EXPIRATION=3600 # 1 hour in seconds
JWT_REFRESH_EXPIRATION=604800 # 7 days in seconds

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Rabbit MQ
RABBITMQ_URL=
RABBITMQ_QUEUE=notification_queue
